{
  "plugins": {
    "superpowers": {
      "enabled": true,
      "capabilities": [
        "code-review",
        "test-generation",
        "documentation",
        "refactoring",
        "security-analysis"
      ]
    },
    "frontend-design-checklist": {
      "enabled": true,
      "capabilities": [
        "design-review",
        "accessibility-check",
        "responsive-design",
        "ui-ux-feedback",
        "component-validation"
      ]
    }
  },
  "development": {
    "pythonPath": "src/",
    "pythonVersion": "3.13"
  },
  "codeStyle": {
    "language": "python",
    "maxLineLength": 100
  }
}
